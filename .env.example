# ==================== ATLANTIC ORDERS API - ENVIRONMENT VARIABLES ====================
# Copiar este archivo a .env y completar con tus valores reales
# NO COMMITEAR .env con valores reales (mantener en .gitignore)

# ==================== DATABASE ====================
# Connection string para SQL Server
# Formato: Server=HOST;Database=DB_NAME;User Id=USER;Password=PASSWORD;TrustServerCertificate=true;
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=AtlanticOrdersDb;User Id=sa;Password=YourPassword123!;TrustServerCertificate=true;

# Usar base de datos en memoria (true) o SQL Server (false)
UseInMemoryDatabase=false

# ==================== JWT AUTHENTICATION ====================
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres para HS256)
# CRÍTICO: Cambiar en producción con valor seguro y largo
Jwt__SecretKey=tu-clave-secreta-super-larga-de-al-menos-32-caracteres-para-hs256-produccion

# Nombre del emisor del token (identificador de tu API)
Jwt__Issuer=AtlanticOrdersApi

# Audiencia del token (cliente que consume la API)
Jwt__Audience=AtlanticOrdersApp

# Tiempo de expiración en minutos
Jwt__ExpirationMinutes=60

# ==================== ASPNETCORE ====================
# Configuración del entorno (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Production

# URLs donde escucha la aplicación (puerto 8080)
ASPNETCORE_URLS=http://+:8080

# ==================== LOGGING ====================
# Nivel de log por defecto (Information, Warning, Error, Critical)
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft_EntityFrameworkCore=Warning
Logging__LogLevel__Microsoft_AspNetCore=Information

# ==================== NOTA IMPORTANTE ====================
# Para Docker:
# 1. Copiar este archivo a .env
# 2. Completar valores para tu entorno
# 3. Ejecutar: docker run --env-file .env -p 8080:8080 atlantic-orders-api:latest
#
# Para Docker Compose:
# 1. Usar el archivo .env automáticamente
# 2. Ejecutar: docker-compose up -d
#
# SEGURIDAD EN PRODUCCIÓN:
# - Usar Azure Key Vault, AWS Secrets Manager, o similar
# - Usar Docker secrets para orquestación (Swarm)
# - Usar Kubernetes secrets para K8s
# - Nunca hardcodear secretos en Dockerfile
# - Usar herramientas de gestión de secretos
