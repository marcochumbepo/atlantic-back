# ==================== ATLANTIC ORDERS API ====================
# Variables de Entorno - SOLO PARA PRODUCCIÓN
# 
# La configuración principal está en: appsettings.json
# Usa estas variables SOLO para sobrescribir valores en producción
#
# USO:
#   docker run -e JWT_SECRET_KEY="tu-clave-segura" ...
#   o en docker-compose.yml en la sección environment:

# ==================== PRODUCCIÓN ====================

# JWT - Variable obligatoria en producción
# Generar clave segura: 
#   dotnet user-secrets set "Jwt:SecretKey" "tu-clave-de-32-caracteres-minimo"
# o usar variable de entorno:
JWT_SECRET_KEY=CAMBIAR_EN_PRODUCCION_A_CLAVE_SEGURA_32_CHARS

# Base de datos (descomentar y configurar para producción)
# ConnectionStrings__DefaultConnection=Server=myserver,1433;Database=AtlanticOrders;User Id=sa;Password=YOUR_PASSWORD;TrustServerCertificate=false;Encrypt=true

# Usar SQL Server en producción (no BD en memoria)
# UseInMemoryDatabase=false

# ==================== EJEMPLO DOCKER-COMPOSE ====================
# services:
#   api:
#     image: atlantic-orders-api:latest
#     environment:
#       - JWT_SECRET_KEY=tu-clave-segura-aqui
#       - UseInMemoryDatabase=false
#       - ConnectionStrings__DefaultConnection=Server=sqlserver,1433;...
