# ==================== ATLANTIC ORDERS API ====================
# Variables de Entorno para diferentes ambientes
# 
# USO:
# - Desarrollo (local): .env.development
# - Testing: .env.test
# - Staging: .env.staging
# - Producción: .env.production (NO COMMITEAR)

# ==================== DEVELOPMENT (.env.development) ====================
# Usar en: docker run --env-file .env.development
# Base: En memoria, logs verbosos, sin validación HTTPS

# Database
ConnectionStrings__DefaultConnection=Server=(localdb)\mssqllocaldb;Database=AtlanticOrdersDb;Trusted_Connection=true;TrustServerCertificate=true;
UseInMemoryDatabase=true

# JWT
Jwt__SecretKey=dev-secret-key-solo-para-desarrollo-32-caracteres
Jwt__Issuer=AtlanticOrdersApi
Jwt__Audience=AtlanticOrdersApp
Jwt__ExpirationMinutes=120

# ASP.NET
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000;https://+:5001

# Logging
Logging__LogLevel__Default=Debug
Logging__LogLevel__Microsoft_EntityFrameworkCore=Debug
Logging__LogLevel__Microsoft_AspNetCore=Debug

# ==================== TESTING (.env.test) ====================
# Usar en: docker run --env-file .env.test
# Base: BD en memoria, logs moderados

# Database
UseInMemoryDatabase=true

# JWT
Jwt__SecretKey=test-secret-key-solo-para-testing-32-caracteres
Jwt__Issuer=AtlanticOrdersApiTest
Jwt__Audience=AtlanticOrdersAppTest
Jwt__ExpirationMinutes=30

# ASP.NET
ASPNETCORE_ENVIRONMENT=Testing
ASPNETCORE_URLS=http://+:8080

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft_EntityFrameworkCore=Warning
Logging__LogLevel__Microsoft_AspNetCore=Warning

# ==================== STAGING (.env.staging) ====================
# Usar en: docker-compose up (actualizar docker-compose.yml)
# Base: SQL Server real, logs controlados, validación HTTPS

# Database
ConnectionStrings__DefaultConnection=Server=mssql,1433;Database=AtlanticOrdersDb;User Id=sa;Password=StagingPassword123!;TrustServerCertificate=true;
UseInMemoryDatabase=false

# JWT
Jwt__SecretKey=staging-secret-key-super-largo-32-caracteres-minimo-cambiar
Jwt__Issuer=AtlanticOrdersApi
Jwt__Audience=AtlanticOrdersApp
Jwt__ExpirationMinutes=60

# ASP.NET
ASPNETCORE_ENVIRONMENT=Staging
ASPNETCORE_URLS=http://+:8080

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft_EntityFrameworkCore=Warning
Logging__LogLevel__Microsoft_AspNetCore=Warning

# ==================== PRODUCTION (.env.production) ====================
# ⚠️ CAMBIAR TODOS LOS VALORES ANTES DE USAR EN PRODUCCIÓN
# 
# INSTRUCCIONES:
# 1. Generar clave JWT segura (32+ caracteres):
#    openssl rand -hex 32  (Linux/Mac)
#    powershell -Command "[Convert]::ToBase64String((1..32|ForEach-Object{[byte](Get-Random -Max 256)})) | tr -d '=' | tr '+/' '-_'"
#
# 2. Usar administrador de secretos:
#    - Azure Key Vault
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Kubernetes Secrets
#
# 3. NO COMMITEAR .env.production
# 4. Usar variables de entorno del sistema / CI-CD
# 5. Auditar acceso a secretos

# Database (Usar servidor SQL Server real)
# REEMPLAZAR: host, database, usuario, contraseña
ConnectionStrings__DefaultConnection=Server=your-production-server.database.windows.net,1433;Database=AtlanticOrdersDb;User Id=sa;Password=YOUR_SECURE_PASSWORD_HERE;TrustServerCertificate=false;Encrypt=true;
UseInMemoryDatabase=false

# JWT (CAMBIAR A VALOR SEGURO)
# ⚠️ CRÍTICO: No usar valores por defecto
# Usar: openssl rand -base64 32
Jwt__SecretKey=CAMBIAR_A_CLAVE_SEGURA_DE_32_CARACTERES_MINIMO
Jwt__Issuer=AtlanticOrdersApi
Jwt__Audience=AtlanticOrdersApp
Jwt__ExpirationMinutes=60

# ASP.NET (Producción)
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=https://+:8080

# Logging (Mínimo)
Logging__LogLevel__Default=Warning
Logging__LogLevel__Microsoft_EntityFrameworkCore=Error
Logging__LogLevel__Microsoft_AspNetCore=Error

# ==================== NOTAS ====================

# SECURITY BEST PRACTICES:
# 
# 1. SECRETOS:
#    - Cambiar Jwt__SecretKey en CADA ambiente
#    - Usar valores aleatorios de 32+ caracteres
#    - Rotarlas regularmente
#
# 2. DATABASE:
#    - No hardcodear credenciales en .env
#    - Usar conexión de BD parametrizada
#    - Usar credenciales con permisos mínimos
#    - Habilitar SSL/TLS en conexión
#
# 3. VARIABLES:
#    - Usar --env-file en local/testing
#    - Usar variables del sistema en producción
#    - Usar secrets manager (Azure/AWS/K8s)
#
# 4. GESTIÓN DE CAMBIOS:
#    - Versionear .env.example
#    - NO commitear .env (añadir a .gitignore)
#    - Revisar cambios de variables en reviews
#    - Auditar acceso a secretos en producción
#
# 5. ROTACIÓN:
#    - Cambiar Jwt__SecretKey cada 90 días
#    - Cambiar credenciales BD cada 180 días
#    - Mantener logs de quién cambió qué
#    - Automatizar rotación en producción

# ==================== EJEMPLO DE USO ====================

# Desarrollo local con BD en memoria:
# cp .env.development .env
# docker run -p 8080:8080 --env-file .env atlantic-orders-api:latest

# Testing con docker-compose:
# cp .env.test .env
# docker-compose up -d

# Producción (RECOMENDADO - usar variables del SO):
# export ConnectionStrings__DefaultConnection="Server=...;User Id=...;Password=..."
# export Jwt__SecretKey="..."
# docker run -p 8080:8080 -e ConnectionStrings__DefaultConnection -e Jwt__SecretKey atlantic-orders-api:latest

# Producción con Kubernetes:
# kubectl create secret generic atlantic-secrets \
#   --from-literal=ConnectionStrings__DefaultConnection="..." \
#   --from-literal=Jwt__SecretKey="..."
