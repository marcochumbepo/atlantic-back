{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "UseInMemoryDatabase": true,
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AtlanticOrdersDb;Trusted_Connection=true;TrustServerCertificate=true;"
  },
  "Jwt": {
    "SecretKey": null,
    "Issuer": "AtlanticOrdersApi",
    "Audience": "AtlanticOrdersApp",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "CookieName": "X-Access-Token",
    "RefreshCookieName": "X-Refresh-Token",
    "CookieSecureFlag": true,
    "CookieSameSite": "Strict"
  },
  "RateLimiting": {
    "EnableRateLimiting": true,
    "IpRateLimitPolicies": {
      "IpWhitelist": [],
      "ClientWhitelist": [],
      "GeneralRule": {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      "LoginRule": {
        "Endpoint": "*:/api/auth/login",
        "Period": "1m",
        "Limit": 5
      }
    }
  }
}


