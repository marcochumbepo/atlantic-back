{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AllowedHosts": "*",
  
  // ==================== DATABASE ====================
  // true = BD en memoria (desarrollo/pruebas)
  // false = SQL Server (producción)
  "UseInMemoryDatabase": true,
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AtlanticOrdersDb;Trusted_Connection=true;TrustServerCertificate=true;"
  },

  // ==================== JWT ====================
  // IMPORTANTE: En producción, usar variable de entorno: JWT_SECRET_KEY
  // o dotnet user-secrets set "Jwt:SecretKey" "tu-clave-segura"
  "Jwt": {
    // Para desarrollo: cualquier clave de 32+ caracteres
    // Para producción: configurar vía variable de entorno JWT_SECRET_KEY
    "SecretKey": "CAMBIAR_ESTE_VALOR_EN_PRODUCCION_MINIMO_32_CARACTERES",
    "Issuer": "AtlanticOrdersApi",
    "Audience": "AtlanticOrdersApp",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "CookieName": "X-Access-Token",
    "RefreshCookieName": "X-Refresh-Token",
    "CookieSecureFlag": true,
    "CookieSameSite": "Strict"
  },

  // ==================== RATE LIMITING ====================
  "RateLimiting": {
    "EnableRateLimiting": true,
    "IpRateLimitPolicies": {
      "IpWhitelist": [],
      "ClientWhitelist": [],
      "GeneralRule": {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      "LoginRule": {
        "Endpoint": "*:/api/auth/login",
        "Period": "1m",
        "Limit": 5
     Rule": {
        "Endpoint": "* },
      "Refresh:/api/auth/refresh",
        "Period": "1m",
        "Limit": 30
      }
    }
  }
}
